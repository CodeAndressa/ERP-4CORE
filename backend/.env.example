# Frontend: apenas URLs públicas. Nunca exponha chaves em variáveis VITE_*
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_PUBLIC_URL=http://127.0.0.1:5174

# Aplicação e segurança
APP_ENV=development
SECRET_KEY=gere_uma_chave_aleatoria_longa
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174
DATABASE_URL=sqlite:///./backend/app.db
BOOTSTRAP_ADMIN_NAME=Andressa Soares
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Financeiro — ASAAS
# Pegue em Asaas > Integrações > Chaves de API
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api.asaas.com/v3

# Métricas, leads e contratos — mesmo Supabase do 4core.site
# Pegue em Supabase > Settings > API. A service_role fica somente no backend.
SITE_SUPABASE_URL=https://uesqdbaxhnblefrtjtae.supabase.co
SITE_SUPABASE_SERVICE_ROLE_KEY=
# Opcional: se vazio, o backend usa o bucket contracts
CONTRACT_STORAGE_BUCKET=contracts
MARKETING_ASSETS_BUCKET=marketing-assets

# Marketing — Meta / Instagram Business
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
META_GRAPH_VERSION=v23.0
META_ACCESS_TOKEN=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Escolha uma string qualquer e cadastre a mesma no campo "Verificar token" do
# webhook no painel da Meta (usado tanto pelo app de Facebook Login quanto pelo
# app "Instagram API com Login do Instagram" abaixo).
META_WEBHOOK_VERIFY_TOKEN=

# Mensagens diretas do Instagram — app SEPARADO no painel da Meta ("API do
# Instagram" / Instagram Login, não o app de Facebook Login acima). O token de
# acesso é colado direto na tela Conexões do ERP (não fica em .env); aqui só
# entram as credenciais fixas do app, necessárias pra trocar o token por um de
# longa duração e pra validar a assinatura do webhook.
INSTAGRAM_LOGIN_APP_ID=
INSTAGRAM_LOGIN_APP_SECRET=

# Assistente IA — Groq
# Pegue em console.groq.com/keys. A chave fica somente no backend.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# GeraÃ§Ã£o das artes do EstÃºdio de ConteÃºdo
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGE_MODEL=@cf/leonardo/lucid-origin
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2

# Use o mesmo valor no backend e no secret MARKETING_CRON_SECRET do GitHub.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
MARKETING_CRON_SECRET=

# E-mail transacional — Resend
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_TO=comercial@4core.site
