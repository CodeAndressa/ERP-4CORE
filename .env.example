# ================================================================
# 4Core ERP — variáveis de ambiente
# Copie como .env para desenvolvimento local.
# Configure também no painel da Vercel (Settings > Environment Variables).
# ================================================================

# --- FRONTEND (Vite) ------------------------------------------------
VITE_API_BASE_URL=http://127.0.0.1:8000

# Em produção (projeto frontend na Vercel), set:
# VITE_API_BASE_URL=https://[seu-projeto-backend].vercel.app

# --- BANCO DE DADOS -------------------------------------------------
# Local: SQLite (padrão, não precisa setar)
# DATABASE_URL=sqlite:///./app.db

# Produção (Supabase): use o Transaction Pooler (porta 6543)
# Supabase → Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres.[ref]:[senha]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- AUTENTICAÇÃO JWT -----------------------------------------------
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-longa-aqui

# --- ADMIN INICIAL --------------------------------------------------
# Criado automaticamente na 1ª inicialização. Idempotente.
BOOTSTRAP_ADMIN_NAME=Sócia 4Core
BOOTSTRAP_ADMIN_EMAIL=seu@email.com
BOOTSTRAP_ADMIN_PASSWORD=senha-segura-aqui

# --- CORS -----------------------------------------------------------
# Separe múltiplas origens com vírgula, sem barra final.
CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174
# Em produção: CORS_ORIGINS=https://[frontend].vercel.app

# --- ASAAS ----------------------------------------------------------
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api.asaas.com/v3

# --- SUPABASE (métricas de site) ------------------------------------
SITE_SUPABASE_URL=https://[project-ref].supabase.co
SITE_SUPABASE_SERVICE_ROLE_KEY=

# --- IA (Groq) ------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- E-MAIL (Resend) ------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_TO=

# --- STORAGE (contratos PDF — Supabase Storage) ---------------------
CONTRACT_STORAGE_BUCKET=contracts
